{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "noEmit": true
  },
  "exclude": ["coverage", "dist", "node_modules"],
  "include": ["src", "__tests__/**/*.ts", "scripts/**/*.ts", "*.config.js", "*.config.mjs", "*.config.ts"]
}
