{
  "name": "setup-acton",
  "description": "GitHub Actions TypeScript template",
  "version": "0.0.0",
  "author": "TON Core",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/ton-blockchain/setup-acton",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ton-blockchain/setup-acton.git"
  },
  "bugs": {
    "url": "https://github.com/ton-blockchain/setup-acton/issues"
  },
  "keywords": [
    "actions",
    "setup",
    "ton",
    "acton"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "bun run format:write && bun run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --passWithNoTests",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "bun run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --passWithNoTests",
    "all": "bun run format:write && bun run lint && bun run test && bun run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/core": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "^10.0.0",
    "@github/local-action": "^7.0.0",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.57.0",
    "ts-jest": "^29.4.0",
    "ts-jest-resolver": "^2.0.0",
    "typescript": "^5.9.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides": {
    "undici": "6.25.0"
  }
}
