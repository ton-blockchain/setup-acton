{
  "name": "setup-acton",
  "version": "0.1.0",
  "private": true,
  "description": "Set up your GitHub Actions workflow with a specific version of Acton",
  "keywords": [
    "actions",
    "setup",
    "ton",
    "ton-blockchain",
    "github-actions",
    "acton"
  ],
  "homepage": "https://github.com/ton-blockchain/setup-acton",
  "bugs": {
    "url": "https://github.com/ton-blockchain/setup-acton/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ton-blockchain/setup-acton.git"
  },
  "license": "MIT",
  "author": "TON Core",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "all": "bun run format && bun run lint && bun run test && bun run package",
    "bundle": "bun run format:write && bun run package",
    "checksums:update": "bun run src/download-current-checksums.ts",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "package": "rimraf ./dist && rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "bun run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --passWithNoTests"
  },
  "overrides": {
    "undici": "6.25.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.0",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/core": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@github/local-action": "^7.0.0",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "jest": "^30.2.0",
    "make-coverage-badge": "^1.2.0",
    "rimraf": "^6.1.0",
    "rollup": "^4.57.0",
    "ts-jest": "^29.4.0",
    "ts-jest-resolver": "^2.0.0",
    "typescript": "^5.9.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
